---
import Layout from "../../layouts/Layout.astro";
import { client } from "../../client.config.js";

let posts = [];
try {
  const res = await fetch(
    `${client.cmsUrl}/api/blog?where[tenant.slug][equals]=${client.tenantSlug}&limit=20&sort=-createdAt`,
  );
  posts = (await res.json()).docs || [];
} catch {}

const displayPosts = posts.length > 0 ? posts : (client.blogPosts || []);
const primary = client.primaryColor || "#4a1a6b";
---

<Layout title="Blog" description={`Expert landscaping tips and news from ${client.name}.`}>
  <!-- Hero Section -->
  <section class="reveal active" style={`
    padding: 12rem 1.5rem 10rem;
    background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)), url('/images/landscaping-5.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    text-align: center;
    color: #fff;
  `}>
    <div class="container" style="position: relative; z-index: 1;">
      <span
        style={`color:#fff; background:${primary}; padding: 0.5rem 1.25rem; border-radius:100px; font-weight:800; font-size:0.85rem; text-transform:uppercase; letter-spacing: 0.1em; display:inline-block; margin-bottom:2rem`}
        >Knowledge & Inspiration</span
      >
      <h1
        style="font-size:clamp(3.5rem, 8vw, 5.5rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -2px; line-height:1; color: #fff;"
      >
        Our Latest <br /><span style={`color: #fff; opacity: 0.8`}>Landscaping Tips</span>
      </h1>
      <p
        style="opacity:0.9; max-width:750px; margin:0 auto; font-size:1.3rem; line-height: 1.6; font-weight: 500;"
      >
        Discover professional insights on garden design, plant care, and outdoor living trends to elevate your home.
      </p>
    </div>
  </section>

  <section style="padding: 2rem 1.5rem 8rem; background: #fff;">
    <div class="container">
      {displayPosts.length > 0 ? (
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(350px, 1fr)); gap:2.5rem">
          {displayPosts.map((post: any, i: number) => (
            <a 
              href={`/blog/${post.slug}`} 
              class={`reveal delay-${(i % 4) + 1} blog-card`}
              style="display:flex; flex-direction:column; border-radius:32px; background:#fff; border:1px solid #f3f4f6; overflow:hidden; text-decoration:none; color:#111; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); height:100%"
            >
              <div style="aspect-ratio:16/10; overflow:hidden; position:relative">
                {post.image?.url ? (
                  <img 
                    src={post.image.url} 
                    alt={post.title} 
                    style="width:100%; height:100%; object-fit:cover; transition: transform 0.8s ease" 
                    class="blog-img"
                  />
                ) : (
                  <div style="width:100%; height:100%; background:#f3f4f6; display:flex; align-items:center; justify-content:center; color:#d1d5db">
                    <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                <div style={`position:absolute; top:1.5rem; left:1.5rem; background:#fff; color:${primary}; padding:0.5rem 1rem; border-radius:100px; font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:1px; box-shadow: 0 4px 10px rgba(0,0,0,0.1)`}>
                  Tips
                </div>
              </div>
              
              <div style="padding:2rem; flex:1; display:flex; flex-direction:column">
                <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1.25rem; color:#6b7280; font-size:0.85rem; font-weight:600">
                  <span style={`width:6px; height:6px; border-radius:50%; background:${primary}`}></span>
                  {post.createdAt ? new Date(post.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : ''}
                </div>
                
                <h2 style="font-size:1.4rem; font-weight:800; margin-bottom:1rem; line-height:1.3; transition: color 0.3s ease" class="blog-title">
                  {post.title}
                </h2>
                
                {post.excerpt && (
                  <p style="color:#6b7280; font-size:1rem; line-height:1.6; margin-bottom:2rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {post.excerpt}
                  </p>
                )}
                
                <div style={`margin-top:auto; display:flex; align-items:center; gap:0.5rem; color:${primary}; font-weight:800; font-size:0.95rem; text-transform:uppercase; letter-spacing:1px`}>
                  Read Article
                  <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="transition: transform 0.3s ease" class="arrow-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div style="text-align:center; padding:6rem 2rem; background:#f9fafb; border-radius:40px; border:2px dashed #e5e7eb">
          <div style="font-size:4rem; margin-bottom:1.5rem">📚</div>
          <h2 style="font-size:1.5rem; font-weight:800; color:#111; margin-bottom:0.75rem">Our Library is Growing</h2>
          <p style="color:#6b7280; font-size:1.1rem; max-width:450px; margin:0 auto">We're currently writing fresh tips and news for you. Check back very soon!</p>
        </div>
      )}
    </div>
  </section>

  <style define:vars={{ primary }}>
    .blog-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 30px 60px -15px rgba(0,0,0,0.1);
      border-color: var(--primary)33;
    }
    .blog-card:hover .blog-img {
      transform: scale(1.05);
    }
    .blog-card:hover .blog-title {
      color: var(--primary);
    }
    .blog-card:hover .arrow-icon {
      transform: translateX(5px);
    }
  </style>
</Layout>