---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Contact Us" description={`Contact ${client.name} for a free estimate. Serving ${client.city}, ${client.state}.`}>

  <!-- Hero Section -->
  <section class="reveal active" style={`
    padding: 12rem 1.5rem 10rem;
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/landscaping-6.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    text-align: center;
    color: #fff;
  `}>
    <div class="container">
      <h1 style="font-size:clamp(3.5rem, 8vw, 5.5rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -2px; line-height: 1;">Contact Us</h1>
      <p style="opacity: 0.9; max-width:700px; margin:0 auto; font-size:1.3rem; line-height: 1.6; font-weight: 500;">
        Ready to start your project? Get in touch with us today for a free, no-obligation estimate.
      </p>
    </div>
  </section>

  <section class="reveal" style="padding:8rem 1.5rem">
    <div class="container">
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(350px, 1fr)); gap:5rem">

        <div style="background:#fff; border-radius:32px; border:1px solid #f3f4f6; padding:3.5rem; box-shadow: 0 10px 40px -15px rgba(0,0,0,0.05)">
          <h2 style="font-size:2rem; font-weight:800; margin-bottom:2.5rem; letter-spacing: -0.5px;">Get a Free Quote</h2>
          <form id="contact-form" style="display:flex; flex-direction:column; gap:1.5rem">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem">
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">First Name *</label>
                <input type="text" name="firstName" required style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; box-sizing:border-box" />
              </div>
              <div>
                <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">Last Name *</label>
                <input type="text" name="lastName" required style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; box-sizing:border-box" />
              </div>
            </div>
            <div>
              <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">Phone Number *</label>
              <input type="tel" name="phone" required style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; box-sizing:border-box" />
            </div>
            <div>
              <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">Email Address</label>
              <input type="email" name="email" style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; box-sizing:border-box" />
            </div>
            <div>
              <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">Service Required *</label>
              <select name="service" required style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; background:#fff; cursor:pointer; box-sizing:border-box">
                <option value="">Select a service...</option>
                {client.services.map((s: string) => <option value={s}>{s}</option>)}
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label style="display:block; font-size:0.85rem; font-weight:700; color:#374151; margin-bottom:0.6rem; text-transform:uppercase; letter-spacing:0.1em">Message</label>
              <textarea name="message" rows="4" placeholder="How can we help you?" style="width:100%; padding:1rem; border:1px solid #e5e7eb; border-radius:12px; font-size:1rem; resize:vertical; box-sizing:border-box"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="padding: 1.25rem; font-size: 1.1rem; border-radius: 12px; width: 100%">
              Send Request
            </button>
          </form>
          <div id="form-success" style="display:none; margin-top:2rem; padding:1.5rem; background:#dcfce7; border-radius:16px; color:#166534; font-weight:600; text-align:center">
            ✓ Thank you! We'll be in touch within 24 hours.
          </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:2rem">
          <h2 style="font-size:2rem; font-weight:800; letter-spacing: -0.5px;">Get in Touch</h2>
          <div style="display:grid; gap:1.5rem">
            {client.phone && (
              <a href={`tel:${client.phone}`} class="reveal" style="display:flex; align-items:center; gap:1.5rem; padding:2rem; border-radius:24px; border:1px solid #f3f4f6; color:#111; background:#fff; transition: all 0.3s ease;" onmouseover="this.style.borderColor=primary" onmouseout="this.style.borderColor='#f3f4f6'">
                <div style={`width:56px; height:56px; border-radius:14px; background:${primary}10; display:flex; align-items:center; justify-content:center; flex-shrink:0; color:${primary}`}>
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p style="font-size:0.85rem; color:#6b7280; font-weight:700; text-transform:uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem">Call Us</p>
                  <p style="font-weight:800; font-size:1.2rem">{client.phone}</p>
                </div>
              </a>
            )}
            {client.email && (
              <a href={`mailto:${client.email}`} class="reveal" style="display:flex; align-items:center; gap:1.5rem; padding:2rem; border-radius:24px; border:1px solid #f3f4f6; color:#111; background:#fff; transition: all 0.3s ease;" onmouseover="this.style.borderColor=primary" onmouseout="this.style.borderColor='#f3f4f6'">
                <div style={`width:56px; height:56px; border-radius:14px; background:${primary}10; display:flex; align-items:center; justify-content:center; flex-shrink:0; color:${primary}`}>
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p style="font-size:0.85rem; color:#6b7280; font-weight:700; text-transform:uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem">Email Us</p>
                  <p style="font-weight:800; font-size:1.2rem">{client.email}</p>
                </div>
              </a>
            )}

            {client.address && (
              <div class="reveal" style="display:flex; align-items:center; gap:1.5rem; padding:2rem; border-radius:24px; border:1px solid #f3f4f6; color:#111; background:#fff">
                <div style={`width:56px; height:56px; border-radius:14px; background:${primary}10; display:flex; align-items:center; justify-content:center; flex-shrink:0; color:${primary}`}>
                  <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p style="font-size:0.85rem; color:#6b7280; font-weight:700; text-transform:uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem">Our Office</p>
                  <p style="font-weight:800; font-size:1.2rem">{client.address}, {client.city}</p>
                </div>
              </div>
            )}
          </div>

          <div class="reveal" style={`padding:2.5rem; border-radius:32px; background:${primary}05; border:1px solid ${primary}10`}>
            <h3 style="font-weight:800; font-size:1.2rem; margin-bottom:1.5rem; letter-spacing: -0.5px;">Service Areas</h3>
            <div style="display:flex; flex-wrap:wrap; gap:0.75rem">
              {client.serviceArea?.map((area: string) => (
                <span style={`background:#fff; color:${primary}; padding:0.5rem 1.25rem; border-radius:50px; font-size:0.9rem; font-weight:700; box-shadow: 0 2px 8px rgba(0,0,0,0.02)`}>{area}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault()
    const form = document.getElementById('contact-form') as HTMLElement
    const success = document.getElementById('form-success') as HTMLElement
    form.style.display = 'none'
    success.style.display = 'block'
  })
</script>