---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'

let testimonials = []
try {
  const res = await fetch(`${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=20`)
  testimonials = (await res.json()).docs || []
} catch {}

const primary = client.primaryColor || '#2d5a3d'
---
<Layout title="Testimonials">
  <!-- Hero Section -->
  <section style={`
    padding: 12rem 1.5rem 10rem;
    background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/landscaping-3.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    text-align: center;
    color: #fff;
  `}>
    <div style="max-width:1200px; margin:0 auto; position:relative; z-index:1">
      <div class="reveal">
        <span style={`color:#fff; background: ${primary}; padding: 0.5rem 1.25rem; border-radius: 100px; font-weight:800; font-size:0.85rem; text-transform:uppercase; letter-spacing: 0.1em; display:inline-block; margin-bottom:2rem`}>Client Stories</span>
        <h1 style="font-size:clamp(3.5rem, 8vw, 5.5rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -2px; line-height:1; color: #fff;">Customer Feedback</h1>
        <p style="opacity: 0.9; font-size:1.3rem; max-width:800px; margin:0 auto; line-height:1.6; font-weight: 500;">Read about the experiences of homeowners who trusted us with their outdoor spaces.</p>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section style="padding:6rem 1.5rem; background:#fff">
    <div style="max-width:1200px; margin:0 auto">
      {testimonials.length > 0 ? (
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(350px, 1fr)); gap:2.5rem">
          {testimonials.map((t: any) => (
            <div class="reveal" style="padding:3rem; border-radius:32px; border:1px solid #f3f4f6; background:#fff; position:relative; transition: all 0.4s ease;" onmouseover="this.style.borderColor=primary; this.style.transform='translateY(-5px)'" onmouseout="this.style.borderColor='#f3f4f6'; this.style.transform='translateY(0)'">
              <div style={`position:absolute; top:2rem; right:2rem; color:${primary}15; font-size:4rem; line-height:1; font-family:serif; pointer-events:none`}>&ldquo;</div>
              <div style="color:#facc15; font-size:1.1rem; margin-bottom:1.5rem; display:flex; gap:2px">
                {"★★★★★".split("").map(() => (
                  <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <p style="color:#4b5563; font-size:1.15rem; font-style:italic; margin-bottom:2rem; line-height:1.8; position:relative; z-index:1">"{t.text || t.content}"</p>
              <div style="display:flex; align-items:center; gap:1.25rem">
                <div style={`width:50px; height:50px; border-radius:50%; background: linear-gradient(135deg, ${primary}, ${primary}cc); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; flex-shrink:0; box-shadow: 0 4px 12px ${primary}40`}>
                  {(t.name || t.author || 'A').charAt(0).toUpperCase()}
                </div>
                <div>
                  <p style="font-weight:800; font-size:1.05rem; margin-bottom:0.15rem">{t.name || t.author}</p>
                  {t.location && <p style="font-size:0.85rem; color:#9ca3af; font-weight:600; text-transform:uppercase; letter-spacing:0.05em">{t.location}</p>}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="reveal" style="text-align:center; padding:6rem 2rem; background:#f9fafb; border-radius:32px; border:2px dashed #e5e7eb">
          <div style={`font-size:4rem; margin-bottom:1.5rem; background:${primary}10; width:100px; height:100px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin: 0 auto 2rem; color:${primary}`}>
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <h2 style="font-size:1.75rem; font-weight:800; margin-bottom:1rem">No Reviews Yet</h2>
          <p style="color:#6b7280; font-size:1.1rem; max-width:400px; margin:0 auto">Be the first to share your experience with us!</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section style="padding:6rem 1.5rem; background:#fff">
    <div style={`max-width:1200px; margin:0 auto; padding:5rem 2rem; border-radius:48px; background: linear-gradient(to right, ${primary}, ${primary}ee); color:#fff; text-align:center; position:relative; overflow:hidden;`} class="reveal">
      <div style="position:absolute; top:0; left:0; width:100%; height:100%; background: url('https://www.transparenttextures.com/patterns/cubes.png'); opacity:0.05"></div>
      <div style="position:relative; z-index:1">
        <h2 style="font-size:clamp(2.25rem, 5vw, 3.5rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -1.5px;">Ready for Your Own Success Story?</h2>
        <p style="font-size:1.25rem; margin-bottom:3rem; opacity:0.9; max-width:650px; margin-left:auto; margin-right:auto">Join hundreds of satisfied homeowners who have elevated their living with Elite Landscaping.</p>
        <a href="/contact" style={`display:inline-block; background:#fff; color:${primary}; padding:1.5rem 3.5rem; border-radius:100px; font-weight:900; text-decoration:none; transition: all 0.3s ease; box-shadow: 0 15px 30px rgba(0,0,0,0.15)`} onmouseover="this.style.transform='translateY(-5px) scale(1.02)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.2)'" onmouseout="this.style.transform='translateY(0) scale(1)'; this.style.boxShadow='0 15px 30px rgba(0,0,0,0.15)'">
          Get Started Today
        </a>
      </div>
    </div>
  </section>

</Layout>