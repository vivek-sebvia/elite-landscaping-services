---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'

let services = []
try {
  const res = await fetch(`${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=50`)
  services = (await res.json()).docs || []
} catch {}

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({ title: s, description: `Expert ${s.toLowerCase()} services by licensed professionals in ${client.city}, ${client.state}.` }))

const primary = client.primaryColor || '#4a1a6b'
---

<Layout title="Services" description={`Professional ${client.industry} services in ${client.city}, ${client.state}.`}>
  <!-- Hero Section -->
  <section class="reveal active" style={`padding:8rem 1.5rem; background: ${primary}05; text-align:center`}>
    <div class="container">
      <h1 style="font-size:clamp(2.5rem, 5vw, 4rem); font-weight:800; margin-bottom:1.5rem; letter-spacing: -1.5px;">Our Specialized Services</h1>
      <p style="color:#6b7280; max-width:600px; margin:0 auto; font-size:1.2rem; line-height: 1.6">
        Providing top-tier {client.industry} solutions with a focus on quality, reliability, and customer satisfaction.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="reveal" style="padding:8rem 1.5rem">
    <div class="container">
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(350px, 1fr)); gap:2.5rem">
        {displayServices.map((service: any) => (
          <div class="reveal" style="display:flex; flex-direction:column; padding:3rem; border-radius:24px; border:1px solid #f3f4f6; background:#fff; transition: all 0.3s ease; box-shadow: 0 4px 20px -10px rgba(0,0,0,0.05);" onmouseover="this.style.borderColor=primary; this.style.transform='translateY(-5px)'" onmouseout="this.style.borderColor='#f3f4f6'; this.style.transform='translateY(0)'">
            <div style={`width:56px; height:56px; border-radius:14px; background:${primary}10; display:flex; align-items:center; justify-content:center; margin-bottom:2rem; color:${primary}`}>
              <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            </div>
            <h2 style="font-size:1.5rem; font-weight:800; margin-bottom:1rem; color:#111">{service.title}</h2>
            <p style="color:#6b7280; font-size:1.05rem; line-height:1.7; margin-bottom:2rem">{service.description}</p>
            <a href="/contact" style={`margin-top:auto; color:${primary}; font-weight:700; display:flex; align-items:center; gap:0.5rem`}>
              Request Estimate
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="reveal" style="padding:4rem 1.5rem">
    <div class="container" style={`background:${primary}; border-radius:40px; padding:6rem 2rem; color:#fff; text-align:center`}>
      <h2 style="font-size:2.5rem; font-weight:800; margin-bottom:1.5rem; letter-spacing: -1px;">Don't See What You're Looking For?</h2>
      <p style="opacity:0.9; margin-bottom:2.5rem; font-size:1.1rem; max-width:600px; margin-left:auto; margin-right:auto">We offer a wide range of custom {client.industry} solutions. Contact us today to discuss your specific needs.</p>
      <div style="display:flex; gap:1.5rem; justify-content:center; flex-wrap:wrap">
        <a href="/contact" class="btn" style="background:#fff; color:var(--primary); padding: 1rem 3rem">Contact Us Now</a>
        <a href={`tel:${client.phone}`} class="btn" style="background:rgba(255,255,255,0.1); color:#fff; border:1px solid rgba(255,255,255,0.3); padding: 1rem 3rem">{client.phone}</a>
      </div>
    </div>
  </section>

</Layout>