---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'

let gallery = []
try {
  const res = await fetch(`${client.cmsUrl}/api/gallery?where[tenant.slug][equals]=${client.tenantSlug}&limit=20`)
  gallery = (await res.json()).docs || []
} catch {}

const primary = client.primaryColor || '#2d5a3d'
---
<Layout title="Gallery">
  <!-- Hero Section -->
  <section style={`padding: 8rem 1.5rem 4rem; background: linear-gradient(135deg, ${primary}15 0%, ${primary}05 100%); text-align:center; position:relative; overflow:hidden;`}>
    <div style={`position:absolute; top:-10%; right:-10%; width:40%; height:80%; background: radial-gradient(circle, ${primary}10 0%, transparent 70%); filter:blur(60px); pointer-events:none`}></div>
    <div style="max-width:1200px; margin:0 auto; position:relative; z-index:1">
      <div class="reveal">
        <span style={`color:${primary}; font-weight:800; font-size:0.9rem; text-transform:uppercase; letter-spacing: 0.2em; display:block; margin-bottom:1rem`}>Visual Excellence</span>
        <h1 style="font-size:clamp(2.5rem, 6vw, 4rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -2px; line-height:1.1">Our Portfolio</h1>
        <p style="color:#6b7280; font-size:1.25rem; max-width:700px; margin:0 auto; line-height:1.6">Browse through our collection of recent transformations and landscaping masterpieces.</p>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section style="padding:6rem 1.5rem; background:#fff">
    <div style="max-width:1200px; margin:0 auto">
      {gallery.length > 0 ? (
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(350px, 1fr)); gap:2rem">
          {gallery.map((item: any) => (
            <div class="reveal" style="border-radius:24px; overflow:hidden; border:1px solid #f3f4f6; background:#fff; transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 20px rgba(0,0,0,0.03);" onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.08)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.03)'">
              <div style="position:relative; overflow:hidden; aspect-ratio:4/3;">
                {item.image?.url && (
                  <img src={item.image.url} alt={item.title || 'Project'} style="width:100%; height:100%; object-fit:cover; transition: transform 0.6s ease;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'" />
                )}
                <div style="position:absolute; bottom:0; left:0; right:0; padding:2rem; background: linear-gradient(transparent, rgba(0,0,0,0.7)); color:#fff">
                  {item.title && <h3 style="font-weight:800; font-size:1.1rem; margin:0">{item.title}</h3>}
                  {item.category && <span style="font-size:0.8rem; opacity:0.8; font-weight:600; text-transform:uppercase; letter-spacing: 0.1em;">{item.category}</span>}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="reveal" style="text-align:center; padding:6rem 2rem; background:#f9fafb; border-radius:32px; border:2px dashed #e5e7eb">
          <div style={`font-size:4rem; margin-bottom:1.5rem; background:${primary}10; width:100px; height:100px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin: 0 auto 2rem; color:${primary}`}>
            <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h2 style="font-size:1.75rem; font-weight:800; margin-bottom:1rem">Portfolio Coming Soon</h2>
          <p style="color:#6b7280; font-size:1.1rem; max-width:400px; margin:0 auto">We're currently documenting our latest projects. Check back soon for new inspiration!</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section style="padding:6rem 1.5rem; background:#fff">
    <div style={`max-width:1200px; margin:0 auto; padding:4rem 2rem; border-radius:40px; background:${primary}; color:#fff; text-align:center; position:relative; overflow:hidden;`} class="reveal">
      <div style="position:absolute; top:0; left:0; width:100%; height:100%; background: url('https://www.transparenttextures.com/patterns/carbon-fibre.png'); opacity:0.1"></div>
      <div style="position:relative; z-index:1">
        <h2 style="font-size:clamp(2rem, 4vw, 3rem); font-weight:900; margin-bottom:1.5rem; letter-spacing: -1px;">Ready for Your Own Transformation?</h2>
        <p style="font-size:1.15rem; margin-bottom:2.5rem; opacity:0.9; max-width:600px; margin-left:auto; margin-right:auto">Let's discuss how we can bring your outdoor vision to life.</p>
        <a href="/contact" style={`display:inline-block; background:#fff; color:${primary}; padding:1.25rem 3rem; border-radius:50px; font-weight:800; text-decoration:none; transition: transform 0.3s ease; box-shadow: 0 10px 20px rgba(0,0,0,0.1)`} onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
          Start Your Project
        </a>
      </div>
    </div>
  </section>

</Layout>