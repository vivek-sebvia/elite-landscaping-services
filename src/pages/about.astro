---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
const primary = client.primaryColor || '#4a1a6b'
---

<Layout title="About Us" description={`Learn about ${client.name} — trusted ${client.industry} professionals in ${client.city}, ${client.state}.`}>

  <!-- Hero Section -->
  <section class="reveal active" style={`padding:8rem 1.5rem; background: ${primary}05; text-align:center`}>
    <div class="container">
      <h1 style="font-size:clamp(2.5rem, 5vw, 4rem); font-weight:800; margin-bottom:1.5rem; letter-spacing: -1.5px;">About {client.name}</h1>
      <p style="color:#6b7280; max-width:600px; margin:0 auto; font-size:1.2rem; line-height: 1.6">
        Dedicated to excellence in {client.industry} since our founding. We're not just contractors; we're your neighbors.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="reveal" style="padding:8rem 1.5rem">
    <div class="container">
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(350px, 1fr)); gap:5rem; align-items:center">
        <div>
          <h2 style="font-size:2.5rem; font-weight:800; margin-bottom:2rem; letter-spacing: -1px;">Who We Are</h2>
          <p style="color:#4b5563; line-height:1.8; margin-bottom:1.5rem; font-size:1.1rem">
            {client.name} is a locally owned and operated {client.industry} company serving {client.city}, {client.state} and the surrounding areas. We take pride in delivering high-quality work at fair prices.
          </p>
          <p style="color:#4b5563; line-height:1.8; margin-bottom:1.5rem; font-size:1.1rem">
            Our team of licensed professionals brings years of hands-on experience to every project. Whether it's a small maintenance task or a large-scale landscape renovation, we treat every job with the same care and professionalism.
          </p>
          <p style="color:#4b5563; line-height:1.8; margin-bottom:3rem; font-size:1.1rem">
            We are fully licensed and insured, giving our customers peace of mind on every job. Our commitment to sustainability and quality ensures your landscape thrives for years to come.
          </p>
          <div style="display:flex; gap:1.5rem; flex-wrap:wrap">
            <a href="/contact" class="btn btn-primary" style="padding: 1rem 2.5rem">Get Free Quote</a>
            <a href={`tel:${client.phone}`} class="btn btn-outline" style="padding: 1rem 2.5rem">Call Us</a>
          </div>
        </div>
        
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1.5rem">
          {[
            { number: '500+', label: 'Projects Completed' },
            { number: '10+', label: 'Years Experience' },
            { number: '100%', label: 'Licensed & Insured' },
            { number: '5★', label: 'Average Rating' },
          ].map(stat => (
            <div style="padding:2.5rem 1.5rem; border-radius:24px; border:1px solid #f3f4f6; text-align:center; background:#fff; box-shadow: 0 4px 15px rgba(0,0,0,0.02)">
              <div style={`font-size:2.5rem; font-weight:800; color:${primary}; margin-bottom:0.5rem; letter-spacing: -1px;`}>{stat.number}</div>
              <div style="font-size:0.95rem; color:#6b7280; font-weight:600; text-transform: uppercase; letter-spacing: 1px;">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="reveal" style="padding:8rem 1.5rem; background:#f9fafb; border-radius: 60px; margin: 0 1.5rem;">
    <div class="container">
      <h2 style="font-size:2.5rem; font-weight:800; text-align:center; margin-bottom:5rem; letter-spacing: -1px;">Our Core Values</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:2rem">
        {[
          { icon: '🤝', title: 'Integrity', desc: 'We do what we say. Honest pricing, transparent processes, and no hidden surprises.' },
          { icon: '⭐', title: 'Quality', desc: 'We use the finest materials and stand behind our work with a 100% satisfaction guarantee.' },
          { icon: '🏠', title: 'Community', desc: `${client.city} is our home. We care about our neighbors and the beauty of our local environment.` },
        ].map(v => (
          <div class="reveal" style="padding:3rem; background:#fff; border-radius:32px; border:1px solid #f3f4f6; text-align:center; transition: transform 0.3s ease" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
            <div style="font-size:3.5rem; margin-bottom:2rem">{v.icon}</div>
            <h3 style="font-weight:800; font-size:1.5rem; margin-bottom:1rem; color:#111">{v.title}</h3>
            <p style="color:#6b7280; font-size:1.05rem; line-height:1.7">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="reveal" style="padding:8rem 1.5rem; text-align:center">
    <div class="container" style={`background:${primary}; border-radius:40px; padding:6rem 2rem; color:#fff`}>
      <h2 style="font-size:2.5rem; font-weight:800; margin-bottom:1.5rem; letter-spacing: -1px;">Ready to Start Your Journey?</h2>
      <p style="opacity:0.9; margin: 0 auto 3rem; font-size:1.2rem; max-width:600px">Contact us today to experience the difference of working with {client.name}.</p>
      <a href="/contact" class="btn" style="background:#fff; color:var(--primary); padding: 1rem 3rem">Get Free Quote</a>
    </div>
  </section>

</Layout>


</Layout>